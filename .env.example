# ============================================================
# VRA File Management System – Environment Variables
# Volta River Authority
# Copy this file to .env and fill in real values
# NEVER commit .env to version control
# ============================================================

# ── Django Core ──────────────────────────────────────────────
DJANGO_SECRET_KEY=your-very-secure-secret-key-change-this-in-production
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,your-vra-domain.com

# ── PostgreSQL Database ───────────────────────────────────────
DB_NAME=vra_fms_db
DB_USER=vra_admin
DB_PASSWORD=your_secure_db_password
DB_HOST=localhost
DB_PORT=5432

# ── Email (Yagmail / Gmail SMTP) ─────────────────────────────
# Create a Gmail App Password at:
# https://myaccount.google.com/apppasswords
YAGMAIL_USER=your_gmail@gmail.com
YAGMAIL_PASSWORD=your_gmail_app_password

EMAIL_HOST_USER=your_gmail@gmail.com
EMAIL_HOST_PASSWORD=your_gmail_app_password
DEFAULT_FROM_EMAIL=noreply@vra.com.gh

# ── Twilio SMS ────────────────────────────────────────────────
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ── Power BI ──────────────────────────────────────────────────
# Register app at: https://app.powerbi.com/apps
# App registrations: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
POWERBI_CLIENT_ID=your-azure-ad-app-client-id
POWERBI_CLIENT_SECRET=your-azure-ad-app-client-secret
POWERBI_TENANT_ID=your-azure-ad-tenant-id
POWERBI_WORKSPACE_ID=your-power-bi-workspace-id
POWERBI_REPORT_ID=your-power-bi-report-id
POWERBI_DATASET_ID=your-power-bi-dataset-id

# ── Reminder Settings ─────────────────────────────────────────
REMINDER_DAYS=3
